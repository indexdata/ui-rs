{
  "name": "@projectreshare/rs",
  "version": "1.99.0",
  "description": "Resource Sharing",
  "repository": {
    "type": "git",
    "url": "https://github.com/openlibraryenvironment/ui-rs"
  },
  "main": "src/index.js",
  "repository": "",
  "license": "Apache-2.0",
  "scripts": {
    "start": "stripes serve",
    "build": "stripes build --output ./output",
    "lint": "eslint src",
    "test": "jest"
  },
  "devDependencies": {
    "@folio/eslint-config-stripes": "~7.1.0",
    "@folio/jest-config-stripes": "~3.0.2",
    "@folio/stripes-cli": "~4.0.0",
    "eslint": "^7.0.0",
    "history": "^4.10.1"
  },
  "dependencies": {
    "@folio/stripes-erm-components": "~9.0.0",
    "@projectreshare/stripes-reshare": "https://github.com/indexdata/stripes-reshare.git#master",
    "classnames": "^2.2.6",
    "final-form": "^4.2.0",
    "graphql-tag": "^2.5.0",
    "json-stable-stringify": "^1.0.1",
    "ky": "^0.23.0",
    "lodash": "^4.17.4",
    "query-string": "^8.1.0",
    "react-final-form": "^6.3.0",
    "react-syntax-highlighter": "^15.5.0",
    "xml-beautify": "^1.2.3"
  },
  "peerDependencies": {
    "@folio/stripes": "^9.0.0 || ^10.0.0",
    "moment": "^2.29.0",
    "react": "*",
    "react-intl": "^6.4.7 || ^7.0.0",
    "react-query": "^3.9.0",
    "react-router": "^5.2.0",
    "react-router-dom": "^5.0.0"
  },
  "resolutions": {
        "@rehooks/local-storage": "2.4.4",
        "postcss-nesting" : "^10.0.0"
  },
  "stripes": {
    "actsAs": [
      "settings"
    ],
    "displayName": "ui-rs.meta.title",
    "route": "/rs",
    "stripesDeps": [
      "@folio/stripes-erm-components",
      "@projectreshare/stripes-reshare"
    ],
    "icons": [
      {
        "name": "app",
        "alt": "Create, view and manage patron requests",
        "title": "Requests"
      }
    ],
    "okapiInterfaces": {
      "crosslink-broker": "1.0",
      "tags": "1.0"
    },
    "permissionSets": [
      {
        "permissionName": "module.rs.enabled",
        "displayName": "UI: resource-sharing module is enabled",
        "visible": true
      },
      {
        "permissionName": "settings.rs.enabled",
        "displayName": "Settings (resource-sharing): settings enabled",
        "subPermissions": [
          "settings.enabled"
        ],
        "visible": false
      }
    ]
  }
}
